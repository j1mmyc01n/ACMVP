# Variables consumed by the browser must be VITE_-prefixed.
# Server-only secrets (no VITE_ prefix) are read inside Netlify Functions.

# Default branding shown to operators when provisioning new locations.
VITE_APP_NAME=ACLOCATION

# Required for the locations module's "provision new tenant" flow.
# These are server-side only and are scoped to the central control-plane site.
NETLIFY_API_TOKEN=
GITHUB_TOKEN=
GITHUB_TEMPLATE_OWNER=
GITHUB_TEMPLATE_REPO=

# Optional: external alerting destination for monitoring module
ALERT_WEBHOOK_URL=
