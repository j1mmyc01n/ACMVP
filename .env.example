# ─── Supabase ───────────────────────────────────────────────────────────────
# Required: Your Supabase project URL (must end in .supabase.co or .supabase.in)
VITE_SUPABASE_URL=https://<project-ref>.supabase.co

# Required: Your Supabase anon/public key (safe to expose in client bundle)
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# Optional: Supabase service role key (NEVER expose in client — server only)
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Optional: Supabase Management API token (used by provision-location function)
SUPABASE_MANAGEMENT_TOKEN=<your-management-token>

# ─── OpenAI / AI ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=<your-openai-key>

# ─── Netlify ─────────────────────────────────────────────────────────────────
# Used by provision-location to create new Netlify sites
NETLIFY_AUTH_TOKEN=<your-netlify-token>

# ─── GitHub ──────────────────────────────────────────────────────────────────
# Used by provision-location and github-agent to manage repos
GITHUB_TOKEN=<your-github-token>
GITHUB_TEMPLATE_OWNER=<org-or-user>
GITHUB_TEMPLATE_REPO=<template-repo-name>

# ─── Stripe (Billing) ────────────────────────────────────────────────────────
# Phase 2 — not yet implemented
STRIPE_SECRET_KEY=<your-stripe-secret>
STRIPE_WEBHOOK_SECRET=<your-stripe-webhook-secret>
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=<your-stripe-publishable-key>
