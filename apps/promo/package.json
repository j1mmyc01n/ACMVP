{
  "name": "@acmvp/promo",
  "version": "0.0.1",
  "private": true,
  "description": "Remotion promo video for the AcuteConnect platform",
  "scripts": {
    "dev":    "remotion studio",
    "render": "remotion render PromoVideo out/promo.mp4 --compositionId=PromoVideo",
    "render:gif": "remotion render PromoVideo out/promo.gif --compositionId=PromoVideo"
  },
  "dependencies": {
    "react":     "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion":  "^4.0.0",
    "@remotion/bundler":   "^4.0.0",
    "@remotion/cli":       "^4.0.0",
    "@remotion/renderer":  "^4.0.0"
  },
  "devDependencies": {
    "@types/react":     "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "typescript":       "^5.4.0"
  },
  "remotion": {
    "entryPoint": "./src/index.ts"
  }
}
